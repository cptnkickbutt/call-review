CALLREVIEW_DB=./data/callreview.db

# Source folders
CX_SOURCE_DIR=./sample_data/cx_incoming
VIP_SOURCE_DIR=./sample_data/vipvoice_incoming

# Final archive roots
ARCHIVE_CX_DIR=./sample_data/archive/WIOGEN-CX
ARCHIVE_VIP_DIR=./sample_data/archive/WIOGEN-TS

# Worker behavior
FILE_STABLE_SECONDS=30
WORKER_SCAN_INTERVAL=15
WORKER_BACKLOG_EVERY=5

# Web
WEB_HOST=127.0.0.1
WEB_PORT=5000

# Optional: if set to 1, worker will not actually move files
DRY_RUN=1